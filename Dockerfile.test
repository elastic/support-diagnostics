FROM docker.elastic.co/wolfi/jdk:openjdk-25.0.2-r2-dev@sha256:05e5fd81a2a335ca2872ee70dcd1cc6b183c412b0e559e5eca648a82872d281d

USER root

WORKDIR /app

COPY . .

CMD ["bash", "-c", "./gradlew --no-daemon --stacktrace test; rc=$?; find build/test-results -name '*.xml' -exec echo '=== {} ===' \\; -exec cat {} \\; 2>/dev/null; exit $rc"]
